# =============================================================================
# Apache Airflow 3.x -- Environment Variables (FAB auth manager)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -- Host UID (WSL2 / Linux) --------------------------------------------------
# Run: echo $(id -u) in your WSL2 terminal and set the value here.
# This ensures files written by Airflow containers are owned by your user.
AIRFLOW_UID=1000

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
# Host-based PostgreSQL. From inside a container the host is reachable as
# host.docker.internal on Docker Desktop (Mac/Windows) and WSL2; on native
# Linux the compose file maps it via extra_hosts. Leave as-is unless your host
# Postgres uses a non-default port.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432

# -- Airflow Core -------------------------------------------------------------
# Generate a Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# -- Airflow API --------------------------------------------------------------
# Generate a secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Also used by the FAB auth manager to sign the login session cookie.
AIRFLOW__API__SECRET_KEY=

# -- Airflow Admin User (FAB auth manager) ------------------------------------
# The admin user is created in the metadata DB by airflow-init via
# `airflow fab-users create`. Unlike SimpleAuthManager, the password is set
# here (not in config/passwords.json). FIRSTNAME/LASTNAME/EMAIL are optional;
# the compose file falls back to sensible defaults if they are left blank.
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com
