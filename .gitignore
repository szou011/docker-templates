# =============================================================================
# .gitignore — Apache Airflow Docker development project
# =============================================================================

# Environment variables — NEVER commit secrets
.env

# SimpleAuthManager credentials — NEVER commit
config/passwords.json

# Airflow logs (can be large and are ephemeral)
logs/

# Domain data produced/consumed by DAGs
data/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# macOS
.DS_Store

# VSCode
.vscode/
