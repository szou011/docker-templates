# =============================================================================
# Apache Airflow 3.x -- Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -- Host UID (WSL2 / Linux) --------------------------------------------------
# Run: echo $(id -u) in your WSL2 terminal and set the value here.
# This ensures files written by Airflow containers are owned by your user.
AIRFLOW_UID=1000

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# -- Airflow Core -------------------------------------------------------------
# Generate a Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# -- Airflow API --------------------------------------------------------------
# Generate a secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__API__SECRET_KEY=

# -- Airflow Admin User -------------------------------------------------------
# Username for the admin user defined in SIMPLE_AUTH_MANAGER_USERS.
# The password is set separately in config/passwords.json (see README).
# NOTE: 'airflow users create' CLI no longer works in Airflow 3.x.
AIRFLOW_ADMIN_USERNAME=admin
